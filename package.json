{
  "name": "floatie",
  "version": "1.0.0",
  "description": "Floating mini browser for YouTube Shorts, TikTok, and Reels",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/ensure-electron.mjs",
    "install:electron": "node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "electron-store": "^11.0.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "playwright-core": "^1.60.0",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "com.floatie.app",
    "productName": "Floatie",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "electronLanguages": ["en-US"],
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "universal"] }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  }
}